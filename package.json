{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "name": "poool",
  "scripts": {
    "lint": "oxlint --type-aware && eslint",
    "test": "vitest run",
    "test:react": "jest packages/eslint-config-react/",
    "test:base": "jest packages/eslint-config/",
    "eslint-base": "yarn workspace @poool/eslint-config",
    "eslint-react": "yarn workspace @poool/eslint-config-react",
    "clean": "turbo run clean",
    "build": "turbo run build",
    "prepack": "yarn build && yarn lint && yarn tsc && yarn test"
  },
  "devDependencies": {
    "@poool/eslint-config": "workspace:^",
    "@poool/eslint-config-react": "workspace:^",
    "@poool/oxfmt-config": "workspace:^",
    "@swc/core": "1.15.43",
    "@swc/jest": "0.2.39",
    "@types/eslint": "9.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "eslint-plugin-oxlint": "1.73.0",
    "jest": "30.4.2",
    "lerna": "9.0.7",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "ts-node": "10.9.2",
    "turbo": "2.10.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  },
  "packageManager": "yarn@4.17.1"
}
